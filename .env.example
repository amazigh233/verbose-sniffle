DATABASE_URL="postgresql://climature:change-me@localhost:5432/climature?schema=public"
SESSION_SECRET="replace-with-at-least-32-random-characters"
ADMIN_USERNAME="climature"
ADMIN_PASSWORD_HASH="$2b$12$replace-this-with-npm-run-hash-password-output"
PORT="3000"
NODE_ENV="development"
HR_PORTAL_ENABLED="false"
# Genereer met: openssl rand -base64 32
HR_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"
HR_KEY_VERSION="v1"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
# Alleen voor lokale tests zonder scanner; wordt in productie geweigerd.
ALLOW_UNSCANNED_HR_FILES="false"
# Verplicht in productie voor gedeelde rate limits en auth-cache.
REDIS_URL="redis://127.0.0.1:6379"
OBJECT_STORAGE_PROVIDER="local"
OBJECT_STORAGE_ROOT=".data/objects"
# Voor S3-compatible opslag: zet provider op s3 en configureer bucket/region/endpoint.
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION="eu-west-1"
OBJECT_STORAGE_ENDPOINT=""
