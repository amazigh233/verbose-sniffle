generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(cuid())
  username                String                  @unique
  email                   String                  @default("")
  passwordHash            String
  role                    String                  @default("installer")
  active                  Boolean                 @default(true)
  mfaSecretCipher         Bytes?
  mfaSecretIv             Bytes?
  mfaSecretTag            Bytes?
  mfaKeyVersion           String                  @default("v1")
  mfaEnabledAt            DateTime?
  mfaLastUsedStep         Int?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  recoveryCodes           UserMfaRecoveryCode[]
  createdContracts        EmploymentContract[]    @relation("ContractCreatedBy")
  createdNotes            EmployeeNote[]          @relation("NoteCreatedBy")
  updatedNotes            EmployeeNote[]          @relation("NoteUpdatedBy")
  hrAuditEvents           HrAuditEvent[]          @relation("HrAuditActor")
  createdQualifications   EmployeeQualification[] @relation("QualificationCreatedBy")
  assignedChecklistItems  EmployeeChecklistItem[] @relation("ChecklistAssignedTo")
  completedChecklistItems EmployeeChecklistItem[] @relation("ChecklistCompletedBy")
  employeeId              String?                 @unique
  employee                Employee?               @relation("EmployeeAccount", fields: [employeeId], references: [id], onDelete: SetNull)
  ownedProjects           CustomerProject[]       @relation("ProjectOwner")
  projectAuditEvents      ProjectAuditEvent[]     @relation("ProjectAuditActor")
  serviceAuditEvents      ServiceAuditEvent[]     @relation("ServiceAuditActor")
  createdPayments         Payment[]               @relation("PaymentCreatedBy")
  cancelledPayments       Payment[]               @relation("PaymentCancelledBy")
  createdPaymentTenders   PaymentTender[]         @relation("PaymentTenderCreatedBy")
  createdPaymentRefunds   PaymentRefund[]         @relation("PaymentRefundCreatedBy")
  openedCashDrawerShifts  CashDrawerShift[]       @relation("CashDrawerShiftOpenedBy")
  closedCashDrawerShifts  CashDrawerShift[]       @relation("CashDrawerShiftClosedBy")

  @@index([role])
  @@index([active])
}

model UserMfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model Employee {
  id                   String                  @id @default(cuid())
  employeeNumber       String                  @unique
  firstName            String
  lastName             String
  workEmail            String                  @default("")
  workPhone            String                  @default("")
  jobTitle             String                  @default("")
  department           String                  @default("")
  status               String                  @default("active")
  employmentType       String                  @default("permanent")
  hoursPerWeek         Float                   @default(0)
  startDate            String
  endDate              String                  @default("")
  privateDataCipher    Bytes?
  privateDataIv        Bytes?
  privateDataTag       Bytes?
  privateDataKeyVersion String                 @default("v1")
  archivedAt           DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  contracts            EmploymentContract[]
  notes                EmployeeNote[]
  installations        Installation[]
  qualifications       EmployeeQualification[]
  checklists           EmployeeChecklist[]
  user                 User?                   @relation("EmployeeAccount")
  projectMemberships   ProjectMember[]
  assignedProjectTasks ProjectTask[]
  workSchedules        EmployeeWorkSchedule[]
  absences             EmployeeAbsence[]
  maintenanceVisits    MaintenanceVisit[]
  serviceRequests      ServiceRequest[]

  @@index([status])
  @@index([department])
  @@index([lastName, firstName])
  @@index([endDate])
}

model EmploymentContract {
  id           String   @id @default(cuid())
  employeeId   String
  title        String
  contractType String   @default("permanent")
  status       String   @default("active")
  startDate    String
  endDate      String   @default("")
  hoursPerWeek Float    @default(0)
  description  String   @default("")
  fileName     String
  mimeType     String   @default("application/pdf")
  size         Int
  sha256       String
  scanStatus   String   @default("quarantine")
  scanMessage  String   @default("")
  storageKey  String   @unique
  keyVersion   String   @default("v1")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([endDate])
  @@index([scanStatus])
}

model EmployeeNote {
  id          String   @id @default(cuid())
  employeeId  String
  category    String   @default("general")
  bodyCipher  Bytes
  bodyIv      Bytes
  bodyTag     Bytes
  keyVersion  String   @default("v1")
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User     @relation("NoteUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([employeeId, createdAt])
}

model HrAuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipHash     String   @default("")
  createdAt  DateTime @default(now())
  actor      User?    @relation("HrAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model QualificationDefinition {
  id                    String                     @id @default(cuid())
  code                  String                     @unique
  name                  String
  kind                  String                     @default("certificate")
  description           String                     @default("")
  evidencePolicy        String                     @default("required")
  defaultValidityMonths Int?
  active                Boolean                    @default(true)
  sortOrder             Int                        @default(0)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  qualifications        EmployeeQualification[]
  requirements          QualificationRequirement[]

  @@index([active, sortOrder])
}

model EmployeeQualification {
  id                  String                  @id @default(cuid())
  employeeId          String
  definitionId        String
  issuer              String                  @default("")
  certificateNumber   String                  @default("")
  issueDate           String                  @default("")
  expiryDate          String                  @default("")
  skillLevel          String                  @default("")
  noteCipher          Bytes?
  noteIv              Bytes?
  noteTag             Bytes?
  evidenceFileName    String                  @default("")
  evidenceMimeType    String                  @default("")
  evidenceSize        Int                     @default(0)
  evidenceSha256      String                  @default("")
  evidenceScanStatus  String                  @default("missing")
  evidenceScanMessage String                  @default("")
  evidenceStorageKey  String?                 @unique
  keyVersion          String                  @default("v1")
  archivedAt          DateTime?
  createdById         String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  employee            Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  definition          QualificationDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  createdBy           User                    @relation("QualificationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([employeeId, archivedAt])
  @@index([definitionId, expiryDate])
  @@index([evidenceScanStatus])
}

model QualificationRequirement {
  id           String                  @id @default(cuid())
  workType     String
  definitionId String
  minimumLevel String                  @default("")
  active       Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  definition   QualificationDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([workType, definitionId])
  @@index([workType, active])
}

model ChecklistTemplate {
  id         String                  @id @default(cuid())
  type       String                  @unique
  name       String
  version    Int                     @default(1)
  active     Boolean                 @default(true)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  items      ChecklistTemplateItem[]
  checklists EmployeeChecklist[]
}

model ChecklistTemplateItem {
  id                String            @id @default(cuid())
  templateId        String
  title             String
  description       String            @default("")
  dueOffsetDays     Int               @default(0)
  required          Boolean           @default(true)
  sortOrder         Int               @default(0)
  defaultAssigneeId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  template          ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model EmployeeChecklist {
  id              String                  @id @default(cuid())
  employeeId      String
  templateId      String?
  type            String
  templateVersion Int
  anchorDate      String
  status          String                  @default("open")
  sourceKey       String                  @unique
  createdAt       DateTime                @default(now())
  completedAt     DateTime?
  employee        Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template        ChecklistTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items           EmployeeChecklistItem[]

  @@index([employeeId, type, createdAt])
  @@index([status])
}

model EmployeeChecklistItem {
  id            String            @id @default(cuid())
  checklistId   String
  title         String
  description   String            @default("")
  dueDate       String
  required      Boolean           @default(true)
  sortOrder     Int               @default(0)
  assignedToId  String?
  status        String            @default("open")
  noteCipher    Bytes?
  noteIv        Bytes?
  noteTag       Bytes?
  keyVersion    String            @default("v1")
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  checklist     EmployeeChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignedTo    User?             @relation("ChecklistAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  completedBy   User?             @relation("ChecklistCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([checklistId, sortOrder])
  @@index([assignedToId, dueDate, status])
  @@index([dueDate, status])
}

model Customer {
  id                 String              @id @default(cuid())
  firstName          String
  lastName           String
  companyName        String              @default("")
  email              String
  phone              String
  address            String
  postalCode         String
  city               String
  notes              String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  notesItems         CustomerNote[]
  documents          CustomerDocument[]
  quotes             Quote[]
  invoices           Invoice[]
  installations      Installation[]
  advices            Advice[]
  salesOpportunities SalesOpportunity[]
  salesAppointments  SalesAppointment[]
  projects           CustomerProject[]
  serviceContracts   ServiceContract[]
  serviceEquipment   CustomerEquipment[]
  serviceRequests    ServiceRequest[]
  maintenanceVisits  MaintenanceVisit[]
  payments           Payment[]

  @@index([email])
  @@index([postalCode])
  @@index([lastName, firstName])
  @@index([city])
  @@index([createdAt])
}

model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  fileName   String
  mimeType   String   @default("application/pdf")
  size       Int      @default(0)
  storageKey String   @unique
  sha256     String   @default("")
  scanStatus String   @default("quarantine")
  scanMessage String  @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Advice {
  id            String   @id @default(cuid())
  customerId    String
  kind          String
  title         String   @default("")
  summary       String   @default("")
  powerKw       Float    @default(0)
  investment    Decimal  @default(0) @db.Decimal(14, 2)
  subsidy       Decimal  @default(0) @db.Decimal(14, 2)
  yearlySaving  Decimal  @default(0) @db.Decimal(14, 2)
  paybackYears  Float    @default(0)
  productName   String   @default("")
  sourceQuoteId String   @default("")
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  date       String
  type       String   @default("Notitie")
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Product {
  id          String   @id @default(cuid())
  category    String
  brand       String
  name        String
  specs       String   @default("")
  priceExVat  Decimal  @db.Decimal(14, 2)
  vatRate     Decimal  @default(21) @db.Decimal(5, 2)
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, brand, name])
  @@index([name])
  @@index([createdAt])
}

model Quote {
  id                 String             @id @default(cuid())
  quoteNumber        String             @unique
  customerId         String
  quoteDate          String
  validUntil         String
  status             String             @default("concept")
  notes              String             @default("")
  templateType       String             @default("maatwerk")
  designStyle        String             @default("licht")
  documentTitle      String             @default("Uw energieoplossing op maat")
  introText          String             @default("")
  includedText       String             @default("")
  advantagesText     String             @default("")
  benefitType        String             @default("geen")
  benefitLabel       String             @default("")
  benefitAmount      Decimal            @default(0) @db.Decimal(14, 2)
  benefits           Json?
  documentConfig     Json?
  sourceAdviceId     String             @default("")
  subtotal           Decimal            @default(0) @db.Decimal(14, 2)
  vat                Decimal            @default(0) @db.Decimal(14, 2)
  total              Decimal            @default(0) @db.Decimal(14, 2)
  acceptedAt         DateTime?
  statusUpdatedAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines              QuoteLine[]
  assets             QuoteAsset[]
  salesOpportunities SalesOpportunity[]
  projects           CustomerProject[]

  @@index([customerId])
  @@index([status])
  @@index([status, quoteDate])
  @@index([createdAt])
  @@index([total])
}

model QuoteAsset {
  id        String   @id @default(cuid())
  quoteId   String
  role      String   @default("product")
  fileName  String
  mimeType  String   @default("image/webp")
  size      Int
  width     Int      @default(0)
  height    Int      @default(0)
  storageKey String  @unique
  sha256     String  @default("")
  scanStatus String  @default("quarantine")
  scanMessage String @default("")
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, createdAt])
}

model SalesOpportunity {
  id                String             @id @default(cuid())
  title             String
  stage             String             @default("lead")
  customerId        String?
  quoteId           String?
  contactName       String             @default("")
  companyName       String             @default("")
  email             String             @default("")
  phone             String             @default("")
  source            String             @default("")
  expectedValue     Decimal            @default(0) @db.Decimal(14, 2)
  probability       Float              @default(10)
  expectedCloseDate String             @default("")
  followUpDate      String             @default("")
  notes             String             @default("")
  lostReason        String             @default("")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quote             Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  appointments      SalesAppointment[]

  @@index([customerId])
  @@index([quoteId])
  @@index([stage])
  @@index([followUpDate])
  @@index([stage, expectedCloseDate])
  @@index([createdAt])
}

model SalesAppointment {
  id            String            @id @default(cuid())
  title         String
  type          String            @default("belafspraak")
  status        String            @default("gepland")
  date          String
  startTime     String            @default("09:00")
  endTime       String            @default("09:30")
  customerId    String?
  opportunityId String?
  contactName   String            @default("")
  location      String            @default("")
  notes         String            @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  customer      Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([date, startTime])
  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([status, date])
  @@index([createdAt])
}

model QuoteLine {
  id                   String  @id @default(cuid())
  quoteId              String
  position             Int
  productId            String  @default("")
  componentKey         String  @default("general")
  lineKind             String  @default("item")
  vatRefundEligible    Boolean @default(false)
  description          String
  qty                  Decimal @db.Decimal(12, 3)
  unit                 String
  priceExVat           Decimal @db.Decimal(14, 2)
  vatRate              Decimal @db.Decimal(5, 2)
  subtotal             Decimal @db.Decimal(14, 2)
  vat                  Decimal @db.Decimal(14, 2)
  total                Decimal @db.Decimal(14, 2)
  quote                 Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Invoice {
  id                  String            @id @default(cuid())
  invoiceNumber       String            @unique
  quoteNumber         String            @default("")
  customerId          String
  invoiceDate         String
  dueDate             String
  status              String            @default("concept")
  paymentInstructions String            @default("")
  notes               String            @default("")
  subtotal            Decimal           @default(0) @db.Decimal(14, 2)
  vat                 Decimal           @default(0) @db.Decimal(14, 2)
  total               Decimal           @default(0) @db.Decimal(14, 2)
  paidAt              DateTime?
  statusUpdatedAt     DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines               InvoiceLine[]
  maintenanceVisit    MaintenanceVisit?
  payment             Payment?

  @@index([customerId])
  @@index([quoteNumber])
  @@index([status])
  @@index([status, dueDate])
  @@index([status, invoiceDate])
  @@index([createdAt])
  @@index([total])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  position    Int
  productId   String  @default("")
  description String
  qty         Decimal @db.Decimal(12, 3)
  unit        String
  priceExVat  Decimal @db.Decimal(14, 2)
  vatRate     Decimal @db.Decimal(5, 2)
  subtotal    Decimal @db.Decimal(14, 2)
  vat         Decimal @db.Decimal(14, 2)
  total       Decimal @db.Decimal(14, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Installation {
  id                 String           @id @default(cuid())
  customerId         String
  quoteId            String           @default("")
  quoteNumber        String           @default("")
  plannedDate        String
  startTime          String           @default("09:00")
  durationHours      Float            @default(4)
  status             String           @default("ingepland")
  installer          String           @default("")
  employeeId         String?
  workType           String           @default("other")
  qualificationCheck Json?
  notes              String           @default("")
  workOrder          Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  employee           Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  project            CustomerProject?

  @@index([customerId])
  @@index([quoteId])
  @@index([plannedDate])
  @@index([status, plannedDate])
  @@index([employeeId])
  @@index([workType])
}

model CustomerProject {
  id                  String              @id @default(cuid())
  projectNumber       String              @unique
  customerId          String
  installationId      String?             @unique
  quoteId             String?
  ownerUserId         String?
  title               String
  workType            String              @default("other")
  status              String              @default("preparation")
  plannedDate         String
  startTime           String              @default("09:00")
  durationHours       Float               @default(4)
  travelBufferMinutes Int                 @default(30)
  internalNotes       String              @default("")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  customer            Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  installation        Installation?       @relation(fields: [installationId], references: [id], onDelete: SetNull)
  quote               Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  owner               User?               @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members             ProjectMember[]
  tasks               ProjectTask[]
  materials           ProjectMaterial[]
  equipment           ProjectEquipment[]
  auditEvents         ProjectAuditEvent[]

  @@index([customerId, createdAt])
  @@index([plannedDate, status])
  @@index([ownerUserId])
}

model ProjectMember {
  id         String          @id @default(cuid())
  projectId  String
  employeeId String
  role       String          @default("assistant")
  createdAt  DateTime        @default(now())
  project    CustomerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@index([employeeId, projectId])
}

model ProjectTemplate {
  id        String                    @id @default(cuid())
  workType  String                    @unique
  name      String
  version   Int                       @default(1)
  active    Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  tasks     ProjectTemplateTask[]
  materials ProjectTemplateMaterial[]
}

model ProjectTemplateTask {
  id            String          @id @default(cuid())
  templateId    String
  title         String
  category      String          @default("preparation")
  description   String          @default("")
  dueOffsetDays Int             @default(-7)
  required      Boolean         @default(true)
  operational   Boolean         @default(true)
  sortOrder     Int             @default(0)
  template      ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ProjectTemplateMaterial {
  id               String          @id @default(cuid())
  templateId       String
  name             String
  sku              String          @default("")
  unit             String          @default("stuk")
  quantity         Float           @default(1)
  supplier         String          @default("")
  leadTimeDays     Int             @default(14)
  safetyMarginDays Int             @default(3)
  neededOffsetDays Int             @default(0)
  sortOrder        Int             @default(0)
  template         ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ProjectTask {
  id                 String          @id @default(cuid())
  projectId          String
  title              String
  category           String          @default("preparation")
  description        String          @default("")
  dueDate            String
  dueOffsetDays      Int             @default(-7)
  automaticDate      Boolean         @default(true)
  required           Boolean         @default(true)
  operational        Boolean         @default(true)
  status             String          @default("open")
  assignedEmployeeId String?
  completedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  project            CustomerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedEmployee   Employee?       @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  @@index([projectId, dueDate, status])
  @@index([assignedEmployeeId, status])
}

model ProjectMaterial {
  id                   String          @id @default(cuid())
  projectId            String
  name                 String
  sku                  String          @default("")
  unit                 String          @default("stuk")
  quantity             Float           @default(1)
  supplier             String          @default("")
  purchasePrice        Decimal         @default(0) @db.Decimal(14, 2)
  leadTimeDays         Int             @default(14)
  safetyMarginDays     Int             @default(3)
  neededOnDate         String
  neededOffsetDays     Int             @default(0)
  orderByDate          String
  automaticDates       Boolean         @default(true)
  expectedDeliveryDate String          @default("")
  status               String          @default("to_determine")
  orderedAt            DateTime?
  receivedAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  project              CustomerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, orderByDate, status])
  @@index([expectedDeliveryDate, status])
}

model EmployeeWorkSchedule {
  id         String   @id @default(cuid())
  employeeId String
  weekday    Int
  startTime  String   @default("08:00")
  endTime    String   @default("17:00")
  active     Boolean  @default(true)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, weekday])
  @@index([weekday, active])
}

model EmployeeAbsence {
  id         String   @id @default(cuid())
  employeeId String
  startDate  String
  endDate    String
  startTime  String   @default("")
  endTime    String   @default("")
  type       String   @default("unavailable")
  note       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, startDate, endDate])
}

model ProjectEquipment {
  id               String          @id @default(cuid())
  projectId        String
  type             String
  brand            String          @default("")
  model            String          @default("")
  serialNumber     String          @default("")
  installedAt      String          @default("")
  warrantyUntil    String          @default("")
  providerCode     String          @default("")
  externalIdCipher Bytes?
  externalIdIv     Bytes?
  externalIdTag    Bytes?
  keyVersion       String          @default("v1")
  connectionStatus String          @default("not_connected")
  lastSyncAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          CustomerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@index([providerCode, connectionStatus])
}

model ProjectAuditEvent {
  id         String          @id @default(cuid())
  projectId  String
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime        @default(now())
  project    CustomerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor      User?           @relation("ProjectAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([actorId, createdAt])
}

model ProjectDigestRun {
  id           String    @id @default(cuid())
  digestDate   String
  recipient    String
  status       String    @default("pending")
  attemptCount Int       @default(0)
  providerId   String    @default("")
  lastError    String    @default("")
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([digestDate, recipient])
  @@index([status, digestDate])
}

model ServiceContract {
  id                   String               @id @default(cuid())
  contractNumber       String               @unique
  customerId           String
  equipmentId          String?
  title                String
  status               String               @default("active")
  startDate            String
  endDate              String               @default("")
  price                Decimal              @default(0) @db.Decimal(14, 2)
  billingPeriod        String               @default("yearly")
  maintenanceFrequency Int                  @default(12)
  nextMaintenanceDate  String               @default("")
  notes                String               @default("")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  customer             Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  equipment            CustomerEquipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  visits               MaintenanceVisit[]
  reminderRuns         ServiceReminderRun[]

  @@index([customerId, status])
  @@index([nextMaintenanceDate, status])
  @@index([equipmentId])
}

model CustomerEquipment {
  id                        String             @id @default(cuid())
  customerId                String
  installationId            String?
  type                      String
  brand                     String             @default("")
  model                     String             @default("")
  serialNumber              String             @default("")
  installedAt               String             @default("")
  warrantyUntil             String             @default("")
  maintenanceIntervalMonths Int                @default(12)
  lastMaintenanceDate       String             @default("")
  nextMaintenanceDate       String             @default("")
  status                    String             @default("active")
  notes                     String             @default("")
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  customer                  Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contracts                 ServiceContract[]
  requests                  ServiceRequest[]
  visits                    MaintenanceVisit[]

  @@index([customerId, status])
  @@index([serialNumber])
  @@index([nextMaintenanceDate, status])
  @@index([warrantyUntil])
}

model ServiceRequest {
  id                 String             @id @default(cuid())
  requestNumber      String             @unique
  customerId         String
  equipmentId        String?
  title              String
  type               String             @default("malfunction")
  priority           String             @default("normal")
  description        String             @default("")
  status             String             @default("open")
  assignedEmployeeId String?
  preferredDate      String             @default("")
  resolvedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  equipment          CustomerEquipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  assignedEmployee   Employee?          @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  visits             MaintenanceVisit[]
  documents          ServiceDocument[]

  @@index([customerId, status])
  @@index([assignedEmployeeId, status])
  @@index([priority, createdAt])
}

model MaintenanceVisit {
  id                 String                   @id @default(cuid())
  visitNumber        String                   @unique
  customerId         String
  equipmentId        String?
  contractId         String?
  serviceRequestId   String?
  assignedEmployeeId String?
  invoiceId          String?                  @unique
  type               String                   @default("maintenance")
  status             String                   @default("scheduled")
  plannedDate        String
  startTime          String                   @default("09:00")
  durationHours      Float                    @default(2)
  workType           String                   @default("other")
  qualificationCheck Json?
  diagnosis          String                   @default("")
  workPerformed      String                   @default("")
  materialsUsed      Json?
  customerName       String                   @default("")
  customerSignature  String                   @default("")
  signedAt           DateTime?
  completedAt        DateTime?
  notes              String                   @default("")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  customer           Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  equipment          CustomerEquipment?       @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  contract           ServiceContract?         @relation(fields: [contractId], references: [id], onDelete: SetNull)
  serviceRequest     ServiceRequest?          @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  assignedEmployee   Employee?                @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  invoice            Invoice?                 @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  measurements       MaintenanceMeasurement[]
  documents          ServiceDocument[]

  @@index([plannedDate, status])
  @@index([assignedEmployeeId, plannedDate])
  @@index([customerId, plannedDate])
  @@index([equipmentId])
}

model MaintenanceMeasurement {
  id        String           @id @default(cuid())
  visitId   String
  name      String
  value     Float
  unit      String           @default("")
  note      String           @default("")
  createdAt DateTime         @default(now())
  visit     MaintenanceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model ServiceDocument {
  id               String            @id @default(cuid())
  serviceRequestId String?
  visitId          String?
  fileName         String
  mimeType         String
  size             Int
  sha256           String
  scanStatus       String            @default("quarantine")
  scanMessage      String            @default("")
  storageKey       String            @unique
  createdAt        DateTime          @default(now())
  serviceRequest   ServiceRequest?   @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  visit            MaintenanceVisit? @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([visitId])
  @@index([scanStatus])
}

model ServiceAuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ServiceAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model ServiceReminderRun {
  id           String          @id @default(cuid())
  contractId   String
  reminderDate String
  status       String          @default("pending")
  providerId   String          @default("")
  lastError    String          @default("")
  sentAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  contract     ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, reminderDate])
  @@index([status, reminderDate])
}

model CashDrawer {
  id        String            @id @default(cuid())
  name      String            @unique
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  shifts    CashDrawerShift[]

  @@index([active, name])
}

model CashDrawerShift {
  id                     String                    @id @default(cuid())
  drawerId               String
  status                 String                    @default("open")
  openingBalance         Decimal                   @db.Decimal(14, 2)
  expectedClosingBalance Decimal?                  @db.Decimal(14, 2)
  closingBalance         Decimal?                  @db.Decimal(14, 2)
  variance               Decimal?                  @db.Decimal(14, 2)
  settlement             Json?
  notes                  String                    @default("")
  openedById             String?
  closedById             String?
  openedAt               DateTime                  @default(now())
  closedAt               DateTime?
  drawer                 CashDrawer                @relation(fields: [drawerId], references: [id], onDelete: Restrict)
  openedBy               User?                     @relation("CashDrawerShiftOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy               User?                     @relation("CashDrawerShiftClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  tenders                PaymentTender[]
  refundAllocations      PaymentRefundAllocation[]
  ledgerEntries          PaymentLedgerEntry[]

  @@index([drawerId, openedAt])
  @@index([status, openedAt])
}

model Payment {
  id                 String               @id @default(cuid())
  invoiceId          String?              @unique
  customerId         String?
  createdById        String?
  cancelledById      String?
  status             String               @default("pending")
  currency           String               @default("EUR")
  subtotal           Decimal              @db.Decimal(14, 2)
  discountAmount     Decimal              @default(0) @db.Decimal(14, 2)
  discountReason     String               @default("")
  tipAmount          Decimal              @default(0) @db.Decimal(14, 2)
  totalAmount        Decimal              @db.Decimal(14, 2)
  paidAmount         Decimal              @default(0) @db.Decimal(14, 2)
  refundedAmount     Decimal              @default(0) @db.Decimal(14, 2)
  cancellationReason String               @default("")
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  invoice            Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customer           Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy          User?                @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  cancelledBy        User?                @relation("PaymentCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  tenders            PaymentTender[]
  refunds            PaymentRefund[]
  receipts           PaymentReceipt[]
  operations         PaymentOperation[]
  ledgerEntries      PaymentLedgerEntry[]

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model PaymentTender {
  id                String                    @id @default(cuid())
  paymentId         String
  shiftId           String?
  createdById       String?
  type              String
  status            String                    @default("captured")
  amount            Decimal                   @db.Decimal(14, 2)
  amountReceived    Decimal                   @db.Decimal(14, 2)
  changeAmount      Decimal                   @default(0) @db.Decimal(14, 2)
  provider          String                    @default("")
  externalReference String                    @default("")
  cardBrand         String                    @default("")
  cardLast4         String                    @default("")
  createdAt         DateTime                  @default(now())
  cancelledAt       DateTime?
  payment           Payment                   @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  shift             CashDrawerShift?          @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  createdBy         User?                     @relation("PaymentTenderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  refundAllocations PaymentRefundAllocation[]

  @@index([paymentId, createdAt])
  @@index([shiftId, type, createdAt])
  @@index([externalReference])
}

model PaymentRefund {
  id          String                    @id @default(cuid())
  paymentId   String
  createdById String?
  amount      Decimal                   @db.Decimal(14, 2)
  reason      String
  createdAt   DateTime                  @default(now())
  payment     Payment                   @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  createdBy   User?                     @relation("PaymentRefundCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  allocations PaymentRefundAllocation[]
  receipt     PaymentReceipt?

  @@index([paymentId, createdAt])
}

model PaymentRefundAllocation {
  id                String           @id @default(cuid())
  refundId          String
  tenderId          String
  shiftId           String?
  amount            Decimal          @db.Decimal(14, 2)
  externalReference String           @default("")
  createdAt         DateTime         @default(now())
  refund            PaymentRefund    @relation(fields: [refundId], references: [id], onDelete: Restrict)
  tender            PaymentTender    @relation(fields: [tenderId], references: [id], onDelete: Restrict)
  shift             CashDrawerShift? @relation(fields: [shiftId], references: [id], onDelete: Restrict)

  @@index([refundId])
  @@index([tenderId, createdAt])
  @@index([shiftId, createdAt])
}

model PaymentReceipt {
  id        String         @id @default(cuid())
  number    String         @unique
  paymentId String
  refundId  String?        @unique
  kind      String
  snapshot  Json
  createdAt DateTime       @default(now())
  payment   Payment        @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  refund    PaymentRefund? @relation(fields: [refundId], references: [id], onDelete: Restrict)

  @@index([paymentId, createdAt])
  @@index([createdAt])
}

model PaymentReceiptSequence {
  year      Int      @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PaymentOperation {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  paymentId      String
  actorId        String
  type           String
  requestHash    String
  createdAt      DateTime @default(now())
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([paymentId, createdAt])
}

model PaymentLedgerEntry {
  id            String           @id @default(cuid())
  paymentId     String?
  shiftId       String?
  aggregateType String
  aggregateId   String
  sequence      Int
  transactionId String
  actorId       String
  eventType     String
  tenderType    String           @default("")
  amount        Decimal          @default(0) @db.Decimal(14, 2)
  currency      String           @default("EUR")
  payload       Json
  previousHash  String           @default("")
  hash          String           @unique
  createdAt     DateTime         @default(now())
  payment       Payment?         @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  shift         CashDrawerShift? @relation(fields: [shiftId], references: [id], onDelete: Restrict)

  @@unique([aggregateType, aggregateId, sequence])
  @@index([paymentId, sequence])
  @@index([shiftId, sequence])
  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Counter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}
