generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                @id @default(cuid())
  username         String                @unique
  passwordHash     String
  role             String                @default("installer")
  active           Boolean               @default(true)
  mfaSecretCipher  Bytes?
  mfaSecretIv      Bytes?
  mfaSecretTag     Bytes?
  mfaEnabledAt     DateTime?
  mfaLastUsedStep  Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  recoveryCodes    UserMfaRecoveryCode[]
  createdContracts EmploymentContract[]  @relation("ContractCreatedBy")
  createdNotes     EmployeeNote[]        @relation("NoteCreatedBy")
  updatedNotes     EmployeeNote[]        @relation("NoteUpdatedBy")
  hrAuditEvents    HrAuditEvent[]        @relation("HrAuditActor")

  @@index([role])
  @@index([active])
}

model UserMfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model Employee {
  id                String               @id @default(cuid())
  employeeNumber    String               @unique
  firstName         String
  lastName          String
  workEmail         String               @default("")
  workPhone         String               @default("")
  jobTitle          String               @default("")
  department        String               @default("")
  status            String               @default("active")
  employmentType    String               @default("permanent")
  hoursPerWeek      Float                @default(0)
  startDate         String
  endDate           String               @default("")
  privateDataCipher Bytes?
  privateDataIv     Bytes?
  privateDataTag    Bytes?
  archivedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  contracts         EmploymentContract[]
  notes             EmployeeNote[]
  installations     Installation[]

  @@index([status])
  @@index([department])
  @@index([lastName, firstName])
  @@index([endDate])
}

model EmploymentContract {
  id           String   @id @default(cuid())
  employeeId   String
  title        String
  contractType String   @default("permanent")
  status       String   @default("active")
  startDate    String
  endDate      String   @default("")
  hoursPerWeek Float    @default(0)
  description  String   @default("")
  fileName     String
  mimeType     String   @default("application/pdf")
  size         Int
  sha256       String
  scanStatus   String   @default("quarantine")
  scanMessage  String   @default("")
  fileCipher   Bytes
  fileIv       Bytes
  fileTag      Bytes
  keyVersion   String   @default("v1")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([endDate])
  @@index([scanStatus])
}

model EmployeeNote {
  id          String   @id @default(cuid())
  employeeId  String
  category    String   @default("general")
  bodyCipher  Bytes
  bodyIv      Bytes
  bodyTag     Bytes
  keyVersion  String   @default("v1")
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User     @relation("NoteUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([employeeId, createdAt])
}

model HrAuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipHash     String   @default("")
  createdAt  DateTime @default(now())
  actor      User?    @relation("HrAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model Customer {
  id                 String             @id @default(cuid())
  firstName          String
  lastName           String
  companyName        String             @default("")
  email              String
  phone              String
  address            String
  postalCode         String
  city               String
  notes              String             @default("")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  notesItems         CustomerNote[]
  documents          CustomerDocument[]
  quotes             Quote[]
  invoices           Invoice[]
  installations      Installation[]
  advices            Advice[]
  salesOpportunities SalesOpportunity[]

  @@index([email])
  @@index([postalCode])
}

model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  fileName   String
  mimeType   String   @default("application/pdf")
  size       Int      @default(0)
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Advice {
  id            String   @id @default(cuid())
  customerId    String
  kind          String
  title         String   @default("")
  summary       String   @default("")
  powerKw       Float    @default(0)
  investment    Float    @default(0)
  subsidy       Float    @default(0)
  yearlySaving  Float    @default(0)
  paybackYears  Float    @default(0)
  productName   String   @default("")
  sourceQuoteId String   @default("")
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  date       String
  type       String   @default("Notitie")
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Product {
  id          String   @id @default(cuid())
  category    String
  brand       String
  name        String
  specs       String   @default("")
  priceExVat  Float
  vatRate     Float    @default(21)
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id                 String             @id @default(cuid())
  quoteNumber        String             @unique
  customerId         String
  quoteDate          String
  validUntil         String
  status             String             @default("concept")
  notes              String             @default("")
  sourceAdviceId     String             @default("")
  subtotal           Float              @default(0)
  vat                Float              @default(0)
  total              Float              @default(0)
  acceptedAt         DateTime?
  statusUpdatedAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines              QuoteLine[]
  salesOpportunities SalesOpportunity[]

  @@index([customerId])
  @@index([status])
}

model SalesOpportunity {
  id                String    @id @default(cuid())
  title             String
  stage             String    @default("lead")
  customerId        String?
  quoteId           String?
  contactName       String    @default("")
  companyName       String    @default("")
  email             String    @default("")
  phone             String    @default("")
  source            String    @default("")
  expectedValue     Float     @default(0)
  probability       Float     @default(10)
  expectedCloseDate String    @default("")
  followUpDate      String    @default("")
  notes             String    @default("")
  lostReason        String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quote             Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([quoteId])
  @@index([stage])
  @@index([followUpDate])
}

model QuoteLine {
  id          String @id @default(cuid())
  quoteId     String
  position    Int
  productId   String @default("")
  description String
  qty         Float
  unit        String
  priceExVat  Float
  vatRate     Float
  subtotal    Float
  vat         Float
  total       Float
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Invoice {
  id                  String        @id @default(cuid())
  invoiceNumber       String        @unique
  quoteNumber         String        @default("")
  customerId          String
  invoiceDate         String
  dueDate             String
  status              String        @default("concept")
  paymentInstructions String        @default("")
  notes               String        @default("")
  subtotal            Float         @default(0)
  vat                 Float         @default(0)
  total               Float         @default(0)
  paidAt              DateTime?
  statusUpdatedAt     DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  customer            Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines               InvoiceLine[]

  @@index([customerId])
  @@index([quoteNumber])
  @@index([status])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  position    Int
  productId   String  @default("")
  description String
  qty         Float
  unit        String
  priceExVat  Float
  vatRate     Float
  subtotal    Float
  vat         Float
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Installation {
  id            String    @id @default(cuid())
  customerId    String
  quoteId       String    @default("")
  quoteNumber   String    @default("")
  plannedDate   String
  startTime     String    @default("09:00")
  durationHours Float     @default(4)
  status        String    @default("ingepland")
  installer     String    @default("")
  employeeId    String?
  notes         String    @default("")
  workOrder     Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([quoteId])
  @@index([plannedDate])
  @@index([employeeId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Counter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}
