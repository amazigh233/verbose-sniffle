    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "multer": "^2.0.2",
    "otplib": "^13.4.1",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "prisma": "^6.13.0",
    "qrcode": "^1.5.4",
    "read-excel-file": "^9.2.0",
